# ═══════════════════════════════════════════════════════════════════════════════
# XPS Intelligence — GitHub Actions Secrets & Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# WHERE TO SET THESE:
#   GitHub → InfinityXOneSystems/XPS-INTELLIGENCE-FRONTEND
#   → Settings → Secrets and variables → Actions
#   → "Secrets" tab for encrypted values (NEVER visible after saving)
#   → "Variables" tab for non-secret build values (visible in logs)
#
# ACCOUNT NEEDED:
#   GitHub organization: InfinityXOneSystems
#   Role: Owner or admin (to manage secrets)
#   URL:  https://github.com/InfinityXOneSystems
#
# SOFTWARE NEEDED (local CLI):
#   npm install -g @github/gh    # OR:
#   brew install gh              # GitHub CLI
#   gh auth login
#
# IMPORTANT NOTES:
#   • GITHUB_TOKEN is AUTOMATICALLY injected by Actions — never set it manually.
#   • Secrets are encrypted with libsodium and are NEVER visible after saving.
#   • Variables are plain-text and visible in workflow logs — non-sensitive only.
#   • All 3 repos share the same GitHub org; some secrets are per-repo.
# ═══════════════════════════════════════════════════════════════════════════════


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SECRETS (encrypted — set under "Secrets" tab)
# Settings path: Repo → Settings → Secrets and variables → Actions → Secrets
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Vercel Deployment ────────────────────────────────────────────────────────
# Used by .github/workflows/deploy.yml → amondnet/vercel-action@v25

# Personal access token for Vercel CLI/API
# How to get:
#   Vercel → https://vercel.com/account/tokens → Create Token
#   Name: "GitHub Actions XPS Frontend"  Scope: "Full Account" or your team
#   Expiration: 90 days (rotate regularly)
VERCEL_TOKEN=your-vercel-token-here

# Vercel team/organization ID
# How to get:
#   Vercel → Team Settings → General → Team ID  (format: team_xxxx)
#   OR for personal: Vercel → Account Settings → General → Your ID
VERCEL_ORG_ID=team_xxxxxxxxxxxxxxxxxxxxxxxx

# Vercel project ID
# How to get:
#   Vercel → Project "xps-intelligence-frontend" → Settings → General → Project ID
#   Format: prj_xxxxxxxxxxxxxxxxxxxxxxxx
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Docker / Webhook Stack ───────────────────────────────────────────────────
# Used by docker-compose.yml webhook-receiver service

# HMAC secret for verifying incoming GitHub webhook payloads
# Generate: openssl rand -hex 32
# Must also be set in: GitHub → Repo → Settings → Webhooks → your hook → Secret
GITHUB_WEBHOOK_SECRET=your-64-char-hex-secret-here

# ── (AUTO-INJECTED — DO NOT SET) ────────────────────────────────────────────
# GITHUB_TOKEN is automatically provided by GitHub Actions with repo-scoped
# permissions. Never create this as a secret — it will conflict.
# GITHUB_TOKEN=<auto>


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# VARIABLES (plain-text — set under "Variables" tab)
# Settings path: Repo → Settings → Secrets and variables → Actions → Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── CI Build ─────────────────────────────────────────────────────────────────
# Passed to `npm run build` in .github/workflows/deploy.yml
# These are non-secret public URLs (visible in CI logs — that is fine)

# Railway backend API URL (same value as API_URL in Vercel)
API_URL=https://xpsintelligencesystem-production.up.railway.app/api

# Railway WebSocket URL
WS_URL=wss://xpsintelligencesystem-production.up.railway.app

# ── Docker Sync ───────────────────────────────────────────────────────────────
# Used by .github/workflows/docker-sync.yml (if present)
# Set to your Railway or self-hosted Docker webhook endpoint
DOCKER_WEBHOOK_URL=https://your-railway-docker-url.up.railway.app/webhook


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# HOW TO APPLY VIA GITHUB WEB UI
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# FOR SECRETS:
# 1. https://github.com/InfinityXOneSystems/XPS-INTELLIGENCE-FRONTEND
# 2. Settings → Secrets and variables → Actions → Secrets → New repository secret
# 3. Enter Name (e.g. VERCEL_TOKEN) and Value → Add secret
#
# FOR VARIABLES:
# 1. Same Settings path → Variables tab → New repository variable
# 2. Enter Name (e.g. API_URL) and Value → Add variable
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# HOW TO APPLY VIA GITHUB CLI (gh)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# Secrets (encrypted):
# gh secret set VERCEL_TOKEN --repo InfinityXOneSystems/XPS-INTELLIGENCE-FRONTEND
# gh secret set VERCEL_ORG_ID --repo InfinityXOneSystems/XPS-INTELLIGENCE-FRONTEND
# gh secret set VERCEL_PROJECT_ID --repo InfinityXOneSystems/XPS-INTELLIGENCE-FRONTEND
# gh secret set GITHUB_WEBHOOK_SECRET --repo InfinityXOneSystems/XPS-INTELLIGENCE-FRONTEND
#
# Variables (plain-text):
# gh variable set API_URL --body "https://xpsintelligencesystem-production.up.railway.app/api" --repo InfinityXOneSystems/XPS-INTELLIGENCE-FRONTEND
# gh variable set WS_URL --body "wss://xpsintelligencesystem-production.up.railway.app" --repo InfinityXOneSystems/XPS-INTELLIGENCE-FRONTEND
# gh variable set DOCKER_WEBHOOK_URL --body "https://..." --repo InfinityXOneSystems/XPS-INTELLIGENCE-FRONTEND
#
# List all current secrets/variables:
# gh secret list --repo InfinityXOneSystems/XPS-INTELLIGENCE-FRONTEND
# gh variable list --repo InfinityXOneSystems/XPS-INTELLIGENCE-FRONTEND
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# GITHUB WEBHOOK SETUP (for Docker local stack)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# To have GitHub notify your local Docker stack on push events:
# 1. Repo → Settings → Webhooks → Add webhook
# 2. Payload URL: http(s)://your-ngrok-or-public-ip:3001/webhook
# 3. Content type: application/json
# 4. Secret: same value as GITHUB_WEBHOOK_SECRET above
# 5. Events: ✅ Push  ✅ Pull request  ✅ Workflow run
#
# For local development with ngrok:
# ngrok http 3001
# Use the ngrok HTTPS URL as the Payload URL
