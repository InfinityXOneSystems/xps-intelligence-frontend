# ═══════════════════════════════════════════════════════════════════════════════
# XPS Intelligence — Railway Backend Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# REPO THIS APPLIES TO: InfinityXOneSystems/XPS_INTELLIGENCE_SYSTEM (backend)
# This file is kept in the FRONTEND repo as a cross-reference only.
# The authoritative copy lives in: XPS_INTELLIGENCE_SYSTEM/docs/env.example
#
# WHERE TO SET THESE:
#   Railway Dashboard → Project "XPS_INTELLIGENCE_SYSTEM"
#   → Your service → Variables tab
#   → Add each variable below
#
# ACCOUNT NEEDED:
#   Sign up:  https://railway.app  (link with your GitHub account)
#   Team:     InfinityXOneSystems workspace
#   Project:  XPS_INTELLIGENCE_SYSTEM
#   Plan:     Hobby ($5/month) or Pro ($20/month) — required for persistent services
#
# SOFTWARE NEEDED (local CLI):
#   npm install -g @railway/cli
#   railway login
#   railway link  (inside XPS_INTELLIGENCE_SYSTEM repo root)
#
# IMPORTANT NOTES:
#   • Railway manages the API server — NOT the database (Supabase handles that).
#   • DATABASE_URL points to Supabase, NOT Railway Postgres.
#   • All Railway secrets are also mirrored into Vercel as BACKEND_URL etc.
#   • Railway keys referenced from Vercel: BACKEND_URL (see .env.vercel.example)
# ═══════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
# SECTION A — Database (Supabase Postgres)
#
# Supabase manages ALL Postgres for this system.
# Do NOT use Railway's built-in Postgres plugin.
#
# How to get DATABASE_URL:
#   Supabase Dashboard → Project "nxfbfbipjsfzoefpgrof"
#   → Settings → Database → Connection String
#   → Choose "URI" mode → copy the connection string
#   → Replace [YOUR-PASSWORD] with your database password
# ─────────────────────────────────────────────────────────────────────────────

# Supabase Postgres connection string (pooled recommended for serverless/Railway)
DATABASE_URL=postgresql://postgres.nxfbfbipjsfzoefpgrof:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# For direct (non-pooled) connections — use for migrations only
# DATABASE_URL_DIRECT=postgresql://postgres.nxfbfbipjsfzoefpgrof:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres


# ─────────────────────────────────────────────────────────────────────────────
# SECTION B — Authentication
# ─────────────────────────────────────────────────────────────────────────────

# JWT signing secret — used to sign/verify auth tokens
# Generate: openssl rand -hex 32
# ❌ Never share or expose this value
JWT_SECRET=your-64-char-hex-secret-here

# Optional: JWT token expiry (default: 7d)
# JWT_EXPIRES_IN=7d


# ─────────────────────────────────────────────────────────────────────────────
# SECTION C — AI / LLM
# ─────────────────────────────────────────────────────────────────────────────

# Groq API key — primary LLM for backend agent execution
# Sign up:  https://groq.com
# API keys: https://console.groq.com/keys → Create API Key
AI_GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI key (optional — secondary/fallback LLM)
# Sign up:  https://platform.openai.com
# API keys: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-...

# Anthropic key (optional)
# Sign up:  https://console.anthropic.com
# API keys: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-api03-...


# ─────────────────────────────────────────────────────────────────────────────
# SECTION D — GitHub Integration
#
# Used by Railway agents to commit scrape results to InfinityXOneSystems/LEADS
# ─────────────────────────────────────────────────────────────────────────────

# GitHub Personal Access Token (classic)
# Required scopes: repo (full) + workflow
# How to get:
#   GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic)
#   → Generate new token (classic)
#   → Select scopes: ✅ repo  ✅ workflow
#   → Generate and copy
# ❌ Never expose this token — it has write access to your repos
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Leads data lake repo coordinates (InfinityXOneSystems/LEADS)
LEADS_REPO_OWNER=InfinityXOneSystems
LEADS_REPO_NAME=LEADS


# ─────────────────────────────────────────────────────────────────────────────
# SECTION E — Redis / BullMQ (optional — Railway Redis plugin)
#
# If using BullMQ for task queuing, add Railway Redis plugin to your project.
# Railway sets REDIS_URL automatically when the plugin is provisioned.
# How to add:
#   Railway Dashboard → Project → New → Database → Add Redis
#   → Railway sets REDIS_URL = redis://default:xxx@xxx.railway.internal:6379
# ─────────────────────────────────────────────────────────────────────────────

# Set automatically by Railway Redis plugin — do not hardcode
# REDIS_URL=redis://default:xxxxxxxx@roundhouse.proxy.rlwy.net:12345


# ─────────────────────────────────────────────────────────────────────────────
# SECTION F — Runtime
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# Port — Railway injects PORT automatically (default: 3000)
# Do NOT hardcode this; Railway assigns the port.
# PORT=3000

# CORS origins — comma-separated list of allowed frontend origins
CORS_ORIGINS=https://xps-intelligence-frontend.vercel.app,https://xps-intelligence-frontend-git-main-jays-projects-5febe7fa.vercel.app


# ─────────────────────────────────────────────────────────────────────────────
# HOW TO APPLY IN RAILWAY DASHBOARD
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. Go to: https://railway.app/dashboard
# 2. Open project: XPS_INTELLIGENCE_SYSTEM
# 3. Click your service (API server)
# 4. Click "Variables" tab
# 5. Click "Raw Editor" (top right) for bulk paste, OR
#    Click "+ New Variable" for individual entry
# 6. Paste or enter each key=value pair above
# 7. Click "Deploy" — Railway redeploys automatically when vars change
#
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO APPLY VIA RAILWAY CLI
# ─────────────────────────────────────────────────────────────────────────────
#
# railway variables set DATABASE_URL="postgresql://..."
# railway variables set JWT_SECRET="$(openssl rand -hex 32)"
# railway variables set AI_GROQ_API_KEY="gsk_..."
# railway variables set GITHUB_TOKEN="ghp_..."
# railway variables set LEADS_REPO_OWNER="InfinityXOneSystems"
# railway variables set LEADS_REPO_NAME="LEADS"
# railway variables set NODE_ENV="production"
#
# View all current variables:
# railway variables
#
# ─────────────────────────────────────────────────────────────────────────────
# RAILWAY WEBHOOKS (notify Vercel on deploy events)
# ─────────────────────────────────────────────────────────────────────────────
#
# Set up Railway to send deployment events to Vercel:
# Railway Dashboard → Project → Settings → Webhooks → Add Webhook
#   URL:    https://<your-vercel-domain>/api/webhooks/railway
#   Events: ✅ DEPLOY_FAILED  ✅ BUILD_FAILED  ✅ SERVICE_CRASH
#           ✅ DEPLOY_SUCCEEDED  ✅ VOLUME_FULL
#   Secret: use same value as GITHUB_WEBHOOK_SECRET in GitHub secrets
#
# This enables the autonomous redeploy loop: Railway failure → Vercel webhook
# → pages/api/webhooks/railway.js → triggers VERCEL_DEPLOY_HOOK recovery.
