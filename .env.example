# ═══════════════════════════════════════════════════════════════════════════════
# XPS Intelligence — Master Environment Variable Reference
# ═══════════════════════════════════════════════════════════════════════════════
#
# SINGLE SOURCE OF TRUTH for every environment variable across the platform.
#
# Platform stack:
#   Vercel    → Frontend + ALL secrets (Groq, Railway keys, Supabase keys)
#   Railway   → Backend (XPS_INTELLIGENCE_SYSTEM repo)
#   Supabase  → Postgres database + auth (Vercel-native integration)
#   GitHub    → Source of truth / source code / CI
#   Docker    → Local development only
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │  PLATFORM-SPECIFIC ENV FILES (copy the right one for your task)          │
# ├──────────────────────────────────────────────────────────────────────────┤
# │  .env.vercel.example   → All Vercel project env vars + setup steps       │
# │  .env.railway.example  → All Railway backend vars + setup steps          │
# │  .env.github.example   → All GitHub Actions secrets + variables          │
# │  .env.supabase.example → Supabase connection + Vercel integration guide  │
# │  .env.docker.example   → Docker local dev stack + commands               │
# │  .env.local.example    → Local dev (Vite npm run dev) — copy to .env.local│
# └──────────────────────────────────────────────────────────────────────────┘
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │  WHERE TO SET THESE VALUES                                               │
# ├──────────────────────────────────────────────────────────────────────────┤
# │  Production        → Vercel → Project → Settings → Environment Variables │
# │  CI/CD (GitHub)    → Repo → Settings → Secrets and Variables             │
# │  Local dev         → Copy .env.local.example to .env.local               │
# │  Backend           → Railway → Project → Variables                        │
# │  Docker local      → Copy .env.docker.example to .env.local              │
# └──────────────────────────────────────────────────────────────────────────┘
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │  ACCOUNTS REQUIRED                                                       │
# ├──────────────────────────────────────────────────────────────────────────┤
# │  Vercel    https://vercel.com/signup                                     │
# │  Railway   https://railway.app  (link GitHub account)                   │
# │  Supabase  https://supabase.com  (free tier available)                   │
# │  GitHub    https://github.com/InfinityXOneSystems                        │
# │  Groq      https://groq.com  (free tier available)                       │
# │  Docker    https://www.docker.com/products/docker-desktop                │
# └──────────────────────────────────────────────────────────────────────────┘
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │  SECURITY RULES (never break these)                                      │
# ├──────────────────────────────────────────────────────────────────────────┤
# │  NEXT_PUBLIC_*  → Baked into browser bundle (Supabase Vercel integration)│
# │  (no prefix)    → Server-side only (Vercel Edge Functions / Railway / CI) │
# │                                                                          │
# │  API_URL and WS_URL are injected at build time by vite.config.ts define. │
# │  They are baked into the bundle as non-prefixed names — no VITE_ needed. │
# │                                                                          │
# │  ❌ NEVER put API keys or secrets in NEXT_PUBLIC_* vars                   │
# │  ❌ NEVER put API keys or secrets in vercel.json (file is committed to git)│
# │  ❌ NEVER commit .env.local to git                                        │
# └──────────────────────────────────────────────────────────────────────────┘
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# FOR LOCAL DEV: cp .env.local.example .env.local  (then fill in values)
# FOR PLATFORM SETUP: see the platform-specific .env.*.example files above
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━


# ─────────────────────────────────────────────────────────────────────────────
# 1. FRONTEND BUILD-TIME URLS (injected into bundle by vite.config.ts define)
#    Set in: Vercel → Environment Variables  AND  .env.local for local dev
#    Account: Vercel → https://vercel.com/signup
#    Project: xps-intelligence-frontend
#    Full guide: .env.vercel.example § SECTION A
# ─────────────────────────────────────────────────────────────────────────────

# Railway backend API base URL — must end in /api
# Get: Railway Dashboard → Project → service → Settings → Domains
API_URL=https://xpsintelligencesystem-production.up.railway.app/api

# WebSocket URL for real-time agent/scraper updates
# Get: same Railway domain, https → wss
WS_URL=wss://xpsintelligencesystem-production.up.railway.app


# ─────────────────────────────────────────────────────────────────────────────
# 2. SUPABASE  (Vercel-native — set automatically by the Supabase integration)
#    Account: Supabase → https://supabase.com (project: nxfbfbipjsfzoefpgrof)
#    Auto-setup: https://vercel.com/integrations/supabase
#    Full guide: .env.supabase.example
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL — public, safe to expose in browser bundle
# Get: Supabase Dashboard → Project → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://nxfbfbipjsfzoefpgrof.supabase.co

# Supabase anon/public key — public (Row Level Security enforces access)
# Get: Supabase Dashboard → Project → Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here


# ─────────────────────────────────────────────────────────────────────────────
# 3. VERCEL SERVERLESS FUNCTIONS (server-side only — NOT baked into bundle)
#    Set in: Vercel → Project → Settings → Environment Variables (Server only)
#    Account: Vercel → jays-projects-5febe7fa / xps-intelligence-frontend
#    Full guide: .env.vercel.example § SECTION C
# ─────────────────────────────────────────────────────────────────────────────

# Railway backend base URL — used by all pages/api/ proxy functions
# ❌ Server-side ONLY — never expose in browser code
BACKEND_URL=https://xpsintelligencesystem-production.up.railway.app

# Groq API key — Vercel-native primary LLM for pages/api/chat.js
# Account: Groq → https://groq.com (free tier available)
# Get: https://console.groq.com/keys → Create API Key
# ❌ Server-side ONLY
AI_GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel deploy hook — triggers autonomous redeploy on Railway failure events
# Get: Vercel → Project → Settings → Git → Deploy Hooks → Add Deploy Hook
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/prj_.../...


# ─────────────────────────────────────────────────────────────────────────────
# 4. GITHUB ACTIONS — SECRETS (encrypted)
#    Set in: GitHub → Repo → Settings → Secrets and variables → Actions → Secrets
#    Account: GitHub → InfinityXOneSystems org
#    CLI: gh secret set NAME --repo InfinityXOneSystems/XPS-INTELLIGENCE-FRONTEND
#    Full guide: .env.github.example
# ─────────────────────────────────────────────────────────────────────────────

# Vercel personal access token — used by deploy.yml
# Get: Vercel → Account Settings → Tokens → Create Token
VERCEL_TOKEN=your-vercel-token-here

# Vercel organization/team ID
# Get: Vercel → Team → Settings → General → Team ID
VERCEL_ORG_ID=team_xxxxxxxxxxxxxxxxxxxxxxxx

# Vercel project ID
# Get: Vercel → Project → Settings → General → Project ID
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxxxxxxxxxxxxx

# HMAC secret for GitHub webhook payload verification
# Generate: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your-64-char-hex-secret-here

# NOTE: GITHUB_TOKEN is injected automatically by GitHub Actions — never set manually.


# ─────────────────────────────────────────────────────────────────────────────
# 5. GITHUB ACTIONS — VARIABLES (non-secret, visible in logs)
#    Set in: GitHub → Repo → Settings → Secrets and variables → Actions → Variables
#    CLI: gh variable set NAME --body "VALUE" --repo InfinityXOneSystems/XPS-INTELLIGENCE-FRONTEND
#    Full guide: .env.github.example
# ─────────────────────────────────────────────────────────────────────────────

# Railway backend API URL for CI builds (same value as §1 API_URL)
API_URL=https://xpsintelligencesystem-production.up.railway.app/api

# WebSocket URL for CI builds (same value as §1 WS_URL)
WS_URL=wss://xpsintelligencesystem-production.up.railway.app

# Docker stack webhook URL (for docker-sync.yml workflow)
DOCKER_WEBHOOK_URL=https://your-railway-docker-url.up.railway.app


# ─────────────────────────────────────────────────────────────────────────────
# 6. RAILWAY BACKEND (XPS_INTELLIGENCE_SYSTEM repo)
#    Set in: Railway → Project → Variables tab
#    Account: Railway → https://railway.app (link GitHub account)
#    Project: XPS_INTELLIGENCE_SYSTEM
#    CLI: railway variables set KEY="VALUE"
#    Full guide: .env.railway.example
#    NOTE: These vars live in the BACKEND repo — listed here for cross-reference.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase Postgres connection string (pooled — for Railway production)
# Get: Supabase → Project → Settings → Database → Connection String → URI
DATABASE_URL=postgresql://postgres.nxfbfbipjsfzoefpgrof:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# JWT signing secret
# Generate: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-here

# Groq API key (backend-side LLM calls by agents)
AI_GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Node environment
NODE_ENV=production

# GitHub PAT — commits scrape results to InfinityXOneSystems/LEADS repo
# Get: GitHub → Settings → Developer settings → Personal access tokens (classic)
# Scopes: repo + workflow
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Leads data lake repo
LEADS_REPO_OWNER=InfinityXOneSystems
LEADS_REPO_NAME=LEADS

# CORS origins (comma-separated Vercel frontend URLs)
CORS_ORIGINS=https://xps-intelligence-frontend.vercel.app


# ─────────────────────────────────────────────────────────────────────────────
# 7. AI / LLM PROVIDERS (optional — Groq is primary; others are fallback)
#    Set in: Vercel → Environment Variables (server-side) AND Railway → Variables
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-...

# Anthropic — https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Google Gemini — https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIzaSy...

# Ollama — local Docker dev only
# OLLAMA_ENDPOINT=http://localhost:11434
# OLLAMA_MODEL=llama3.2

