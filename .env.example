# ─────────────────────────────────────────────────────────────
# XPS Intelligence Frontend — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env (local dev) or set these variables in
# your Vercel project settings (Production / Preview).
#
# Vercel dashboard: Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# ── Backend (Railway) ────────────────────────────────────────
# URL of the XPS Intelligence System backend deployed on Railway.
# In Vercel this variable is baked into the bundle at build time.
VITE_API_URL=https://xps-intelligence-system.up.railway.app/api

# WebSocket URL (optional — for real-time scraper updates)
# VITE_WS_URL=wss://xps-intelligence-system.up.railway.app

# ── Vercel Serverless Functions ───────────────────────────────
# Used by pages/api/agent.ts to proxy requests to the Railway backend.
# Set this in the Vercel dashboard under Environment Variables.
BACKEND_URL=https://xps-intelligence-system.up.railway.app

# ── Supabase ─────────────────────────────────────────────────
# Standard Supabase variable names — set automatically by the Supabase
# Vercel integration. vite.config.ts adds 'NEXT_PUBLIC_' to envPrefix
# so these are baked into the Vite bundle at build time without needing
# separate VITE_* aliases.
#
# In Vercel the Supabase integration sets these automatically.
# For local dev, add them to .env.local (see .env.local.example).
NEXT_PUBLIC_SUPABASE_URL=https://nxfbfbipjsfzoefpgrof.supabase.co
# Anon/public key — set by Supabase Vercel integration automatically:
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ── Webhooks ──────────────────────────────────────────────────
# Vercel Deploy Hook — server-side only (never use VITE_ or NEXT_PUBLIC_ prefix).
# Used by /api/webhooks/railway to trigger autonomous redeploys on
# critical Railway events (DEPLOY_FAILED, SERVICE_CRASH, BUILD_FAILED).
# Set this in Vercel project → Settings → Environment Variables.
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/prj_eNK90PC48eWsMW3O6aHHRWsM4wwI/ugf4FE56k4

# ── Railway Webhook Setup ─────────────────────────────────────
# In Railway dashboard: Project → Settings → Webhooks → New Webhook
# Webhook URL: https://<your-vercel-domain>/api/webhooks/railway
# Recommended events: DEPLOY_FAILED, BUILD_FAILED, SERVICE_CRASH,
#                     DEPLOY_SUCCEEDED, VOLUME_FULL

# ── LLM Providers ────────────────────────────────────────────
# Groq API key — used server-side by pages/api/chat.js and
# client-side via Settings → Integrations → Groq.
AI_GROQ_API_KEY=gsk_...

# Optional additional LLM providers (configure in Settings UI)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
