# ═══════════════════════════════════════════════════════════════════════════════
# XPS Intelligence — Master Environment Variable Reference
# ═══════════════════════════════════════════════════════════════════════════════
#
# SINGLE SOURCE OF TRUTH for every environment variable across the platform.
#
# Platform stack:
#   Vercel    → Frontend + ALL secrets (Groq, Railway keys, Supabase keys)
#   Railway   → Backend (XPS_INTELLIGENCE_SYSTEM repo)
#   Supabase  → Postgres database + auth
#   GitHub    → Source of truth / source code / CI
#   Docker    → Local development only
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │  WHERE TO SET THESE VALUES                                               │
# ├──────────────────────────────────────────────────────────────────────────┤
# │  Production        → Vercel → Project → Settings → Environment Variables │
# │  CI/CD (GitHub)    → Repo → Settings → Secrets and Variables             │
# │  Local dev         → Copy this file to .env.local (git-ignored)          │
# │  Backend           → Railway → Project → Variables                        │
# └──────────────────────────────────────────────────────────────────────────┘
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │  SECURITY RULES (never break these)                                      │
# ├──────────────────────────────────────────────────────────────────────────┤
# │  NEXT_PUBLIC_*  → Baked into browser bundle (Supabase Vercel integration)│
# │  (no prefix)    → Server-side only (Vercel Edge Functions / Railway / CI) │
# │                                                                          │
# │  API_URL and WS_URL are injected at build time by vite.config.ts define. │
# │  They are baked into the bundle as non-prefixed names — no VITE_ needed. │
# │                                                                          │
# │  ❌ NEVER put API keys or secrets in NEXT_PUBLIC_* vars                   │
# │  ❌ NEVER put API keys or secrets in vercel.json (use Vercel dashboard)   │
# └──────────────────────────────────────────────────────────────────────────┘
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# COPY & FILL IN: cp .env.example .env.local
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━


# ─────────────────────────────────────────────────────────────────────────────
# 1. FRONTEND BUILD-TIME URLS (injected into bundle by vite.config.ts define)
#    Set in: Vercel → Environment Variables  AND  .env.local for local dev
#    Account: Vercel (jays-projects-5febe7fa / xps-intelligence-frontend)
# ─────────────────────────────────────────────────────────────────────────────

# Railway backend API base URL — must end in /api
API_URL=https://xpsintelligencesystem-production.up.railway.app/api

# WebSocket URL for real-time agent/scraper updates
WS_URL=wss://xpsintelligencesystem-production.up.railway.app


# ─────────────────────────────────────────────────────────────────────────────
# 2. SUPABASE  (Vercel-native — set automatically by the Supabase integration)
#    Set in: Supabase dashboard → Project → Settings → API  AND  .env.local
#    Account: Supabase (project: nxfbfbipjsfzoefpgrof)
#    Supabase manages Postgres for the entire system.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL — public, safe to expose in browser bundle
NEXT_PUBLIC_SUPABASE_URL=https://nxfbfbipjsfzoefpgrof.supabase.co

# Supabase anon/public key — public, safe to expose (Row Level Security enforces access)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here


# ─────────────────────────────────────────────────────────────────────────────
# 3. VERCEL SERVERLESS FUNCTIONS (server-side only — NOT baked into bundle)
#    Set in: Vercel → Project → Settings → Environment Variables
#    Account: Vercel (jays-projects-5febe7fa / xps-intelligence-frontend)
#    ALL secrets live here — Vercel is the secrets vault for the frontend.
# ─────────────────────────────────────────────────────────────────────────────

# Railway backend base URL — used by all pages/api/ proxy functions
BACKEND_URL=https://xpsintelligencesystem-production.up.railway.app

# Groq API key — Vercel-native; used by pages/api/chat.js for LLM completions
# Get from: https://console.groq.com/keys
AI_GROQ_API_KEY=gsk_...

# Vercel deploy hook — triggers autonomous redeploy on critical Railway failures
# Get from: Vercel → Project → Settings → Git → Deploy Hooks
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/prj_.../...


# ─────────────────────────────────────────────────────────────────────────────
# 4. GITHUB ACTIONS — SECRETS (encrypted, never visible in logs)
#    Set in: GitHub → Repo → Settings → Secrets and Variables → Actions → Secrets
#    Account: GitHub (InfinityXOneSystems org)
# ─────────────────────────────────────────────────────────────────────────────

# Vercel personal access token — used by deploy.yml to deploy to Vercel
# Get from: Vercel → Account Settings → Tokens
VERCEL_TOKEN=your-vercel-token-here

# Vercel organization/team ID
# Get from: Vercel → Team → Settings → General → Team ID
VERCEL_ORG_ID=your-vercel-org-id-here

# Vercel project ID
# Get from: Vercel → Project → Settings → General → Project ID
VERCEL_PROJECT_ID=your-vercel-project-id-here

# HMAC secret for verifying GitHub webhook payloads to the Docker stack
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# NOTE: GITHUB_TOKEN is injected automatically by GitHub Actions — never set manually.


# ─────────────────────────────────────────────────────────────────────────────
# 5. GITHUB ACTIONS — VARIABLES (non-secret, visible in logs)
#    Set in: GitHub → Repo → Settings → Secrets and Variables → Actions → Variables
#    Account: GitHub (InfinityXOneSystems org)
# ─────────────────────────────────────────────────────────────────────────────

# Railway backend API URL for CI builds (same value as API_URL above)
API_URL=https://xpsintelligencesystem-production.up.railway.app/api

# WebSocket URL for CI builds
WS_URL=wss://xpsintelligencesystem-production.up.railway.app

# Docker stack webhook URL (for docker-sync.yml workflow)
DOCKER_WEBHOOK_URL=https://your-railway-docker-url.up.railway.app


# ─────────────────────────────────────────────────────────────────────────────
# 6. RAILWAY BACKEND (XPS_INTELLIGENCE_SYSTEM repo)
#    Set in: Railway → Project → Variables
#    Account: Railway (linked to GitHub InfinityXOneSystems org)
#    NOTE: These vars live in the BACKEND repo — listed here for reference only.
#    Railway keys are also mirrored in Vercel as BACKEND_URL etc. (see §3).
# ─────────────────────────────────────────────────────────────────────────────

# Supabase DB connection string — Railway connects to Supabase Postgres
DATABASE_URL=postgresql://...  # from Supabase: Project → Settings → Database → Connection String

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-here

# Groq API key (backend-side LLM calls)
AI_GROQ_API_KEY=gsk_...

# Node environment
NODE_ENV=production

# GitHub PAT with repo+workflow write access — commits scrape results to LEADS repo
# Get from: GitHub → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=ghp_...

# Leads data lake repo (InfinityXOneSystems/LEADS)
LEADS_REPO_OWNER=InfinityXOneSystems
LEADS_REPO_NAME=LEADS


# ─────────────────────────────────────────────────────────────────────────────
# 7. AI / LLM PROVIDERS (optional — Groq is primary, others are optional)
#    Set in: Vercel → Environment Variables (server-side only)
#    Account: each provider's dashboard
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AI...

# Ollama — local model endpoint (Docker dev only)
# OLLAMA_ENDPOINT=http://localhost:11434

