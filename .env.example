# ═══════════════════════════════════════════════════════════════════════════════
# XPS Intelligence — Master Environment Variable Reference
# ═══════════════════════════════════════════════════════════════════════════════
#
# This is the SINGLE SOURCE OF TRUTH for every environment variable used across
# the XPS Intelligence platform.
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │  WHERE TO SET THESE VALUES                                               │
# ├──────────────────────────────────────────────────────────────────────────┤
# │  Production (Vercel)   → Project → Settings → Environment Variables      │
# │  CI/CD (GitHub)        → Repo → Settings → Secrets and Variables         │
# │  Local dev             → Copy this file to .env.local (git-ignored)      │
# │  Backend (Railway)     → Project → Variables                             │
# └──────────────────────────────────────────────────────────────────────────┘
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │  PREFIX RULES (CRITICAL — never break these)                             │
# ├──────────────────────────────────────────────────────────────────────────┤
# │  VITE_*          → Baked into browser bundle at Vite build time          │
# │  NEXT_PUBLIC_*   → Also baked into bundle (Supabase Vercel integration)  │
# │  (no prefix)     → Server-side only (Vercel Edge / Railway / CI)         │
# │                                                                          │
# │  ❌ NEVER prefix AI keys, tokens, or secrets with VITE_ or NEXT_PUBLIC_  │
# │  ✅ Only bake in non-sensitive URLs (API endpoints, Supabase project URL) │
# └──────────────────────────────────────────────────────────────────────────┘
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │  VERCEL OIDC (keyless auth — no long-lived tokens needed)                │
# ├──────────────────────────────────────────────────────────────────────────┤
# │  Vercel automatically issues short-lived OIDC tokens for each deployment │
# │  that can authenticate with AWS, GCP, and other OIDC-capable providers   │
# │  WITHOUT storing static credentials:                                     │
# │                                                                          │
# │    iss:  https://oidc.vercel.com/jays-projects-5febe7fa                  │
# │    aud:  https://vercel.com/jays-projects-5febe7fa                       │
# │    sub:  owner:jays-projects-5febe7fa:project:xps-intelligence-frontend: │
# │          environment:production                                           │
# │                                                                          │
# │  To use OIDC for AWS: configure an IAM Identity Provider for             │
# │    https://oidc.vercel.com/jays-projects-5febe7fa and trust the sub.     │
# │  To use OIDC for GCP: configure a Workload Identity Federation pool.     │
# │  Both approaches replace AWS_ACCESS_KEY_ID/GCP_SERVICE_ACCOUNT_KEY.      │
# └──────────────────────────────────────────────────────────────────────────┘
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# COPY & FILL IN: cp .env.example .env.local
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━


# ─────────────────────────────────────────────────────────────────────────────
# 1. FRONTEND RUNTIME (baked into browser bundle — non-sensitive URLs only)
#    Set in: Vercel → Environment Variables  AND  .env.local for local dev
#    Account: Vercel (jays-projects-5febe7fa / xps-intelligence-frontend)
# ─────────────────────────────────────────────────────────────────────────────

# Backend Railway API base URL — must end in /api
VITE_API_URL=https://xpsintelligencesystem-production.up.railway.app/api

# WebSocket URL for real-time agent/scraper updates
VITE_WS_URL=wss://xpsintelligencesystem-production.up.railway.app


# ─────────────────────────────────────────────────────────────────────────────
# 2. SUPABASE  (set by Supabase Vercel integration automatically in production)
#    Set in: Supabase dashboard → Project → Settings → API  AND  .env.local
#    Account: Supabase (project: nxfbfbipjsfzoefpgrof)
#    Note: vite.config.ts sets envPrefix: ['VITE_', 'NEXT_PUBLIC_'] so
#          NEXT_PUBLIC_* vars are baked into the bundle just like VITE_* vars.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL — public, safe to expose in browser bundle
NEXT_PUBLIC_SUPABASE_URL=https://nxfbfbipjsfzoefpgrof.supabase.co

# Supabase anon/public key — public, safe to expose (RLS enforces security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here


# ─────────────────────────────────────────────────────────────────────────────
# 3. VERCEL SERVERLESS FUNCTIONS (server-side only — never add VITE_ prefix)
#    Set in: Vercel → Settings → Environment Variables (NOT baked into bundle)
#    Account: Vercel (jays-projects-5febe7fa / xps-intelligence-frontend)
# ─────────────────────────────────────────────────────────────────────────────

# Railway backend base URL — used by all pages/api/ proxy functions
BACKEND_URL=https://xpsintelligencesystem-production.up.railway.app

# Groq API key — used by pages/api/chat.js for LLM completions
AI_GROQ_API_KEY=gsk_...

# Vercel deploy hook — triggers autonomous redeploy on critical Railway failures
# Get from: Vercel → Project → Settings → Git → Deploy Hooks
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/prj_.../...


# ─────────────────────────────────────────────────────────────────────────────
# 4. GITHUB ACTIONS CI/CD SECRETS
#    Set in: GitHub → Repo → Settings → Secrets and Variables → Actions → Secrets
#    Account: GitHub (InfinityXOneSystems org)
# ─────────────────────────────────────────────────────────────────────────────

# Vercel deployment token
# Get from: Vercel → Account Settings → Tokens
VERCEL_TOKEN=your-vercel-token-here

# Vercel organization ID (team slug, not name)
# Get from: Vercel → Team → Settings → General → Team ID
VERCEL_ORG_ID=your-vercel-org-id-here

# Vercel project ID
# Get from: Vercel → Project → Settings → General → Project ID
VERCEL_PROJECT_ID=your-vercel-project-id-here

# HMAC secret for verifying GitHub webhook payloads sent to the Docker stack
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# NOTE: GITHUB_TOKEN is automatically provided by GitHub Actions — do NOT set this manually.


# ─────────────────────────────────────────────────────────────────────────────
# 5. GITHUB ACTIONS CI/CD VARIABLES (non-secret, visible in logs)
#    Set in: GitHub → Repo → Settings → Secrets and Variables → Actions → Variables
#    Account: GitHub (InfinityXOneSystems org)
# ─────────────────────────────────────────────────────────────────────────────

# Backend Railway API URL for CI builds (same as VITE_API_URL)
VITE_API_URL=https://xpsintelligencesystem-production.up.railway.app/api

# WebSocket URL for CI builds
VITE_WS_URL=wss://xpsintelligencesystem-production.up.railway.app

# Docker stack webhook URL (for docker-sync.yml workflow)
DOCKER_WEBHOOK_URL=https://your-railway-docker-url.up.railway.app


# ─────────────────────────────────────────────────────────────────────────────
# 6. RAILWAY BACKEND (XPS_INTELLIGENCE_SYSTEM)
#    Set in: Railway → Project → Variables
#    Account: Railway (linked to GitHub InfinityXOneSystems org)
#    NOTE: These vars belong to the BACKEND repo — listed here for cross-repo reference.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string — set automatically by Railway Postgres plugin
DATABASE_URL=postgresql://...

# Redis connection string — set automatically by Railway Redis plugin
REDIS_URL=redis://...

# JWT signing secret (generate with: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-here

# Groq API key — same key as frontend, or a separate backend key
AI_GROQ_API_KEY=gsk_...

# Node environment
NODE_ENV=production

# GitHub PAT with repo+workflow write permissions — used by lead_repository_client
# to commit scrape results to InfinityXOneSystems/LEADS repo
GITHUB_TOKEN=ghp_...

# Leads data lake repo coordinates
LEADS_REPO_OWNER=InfinityXOneSystems
LEADS_REPO_NAME=LEADS


# ─────────────────────────────────────────────────────────────────────────────
# 7. AI / LLM PROVIDERS (optional — configure additional providers as needed)
#    Set in: Vercel → Environment Variables  (server-side, no VITE_ prefix)
#    OR:     Railway → Variables  (for backend-side LLM calls)
#    Account: Each respective provider dashboard
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AI...

# Ollama (local) — URL of local Ollama server (safe to expose as VITE_ if public)
# VITE_OLLAMA_ENDPOINT=http://localhost:11434


# ─────────────────────────────────────────────────────────────────────────────
# 8. CLOUD INTEGRATIONS (optional — configure as needed)
#    If using Vercel OIDC (recommended), AWS/GCP keys are NOT needed.
#    See the OIDC section at the top of this file.
#    Account: respective cloud provider
# ─────────────────────────────────────────────────────────────────────────────

# AWS — skip if using Vercel OIDC keyless auth
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1
# AWS_S3_BUCKET=xps-intelligence-leads

# GCP — skip if using Vercel OIDC keyless auth
# GCP_PROJECT_ID=xps-intelligence
# GCP_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Cloudflare (optional CDN / R2 storage)
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_ACCOUNT_ID=...
# CLOUDFLARE_R2_BUCKET=xps-leads


# ─────────────────────────────────────────────────────────────────────────────
# 9. GOOGLE DRIVE MIRROR (for LEADS repo sync_drive workflow)
#    Set in: GitHub → Repo Settings (InfinityXOneSystems/LEADS) → Secrets
#    Account: Google Cloud / Google Drive API
# ─────────────────────────────────────────────────────────────────────────────

# Google service account JSON key — used by LEADS repo .github/workflows/sync_drive.yml
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Google Drive folder ID to mirror LEADS repo into
# GOOGLE_DRIVE_FOLDER_ID=1AbcDef...

