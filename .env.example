# ─────────────────────────────────────────────────────────────
# XPS Intelligence Frontend — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env (local dev) or set these variables in
# your Vercel project settings (Production / Preview).
#
# Vercel dashboard: Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# ── Backend (Railway) ────────────────────────────────────────
# URL of the XPS Intelligence System backend deployed on Railway.
# In Vercel this variable is baked into the bundle at build time.
VITE_API_URL=https://xpsintelligencesystem-production.up.railway.app/api

# WebSocket URL (for real-time scraper and agent updates)
VITE_WS_URL=wss://xpsintelligencesystem-production.up.railway.app

# ── Vercel Serverless Functions ───────────────────────────────
# Used by pages/api/*.js to proxy requests to the Railway backend.
# Set this in the Vercel dashboard under Environment Variables.
BACKEND_URL=https://xpsintelligencesystem-production.up.railway.app

# ── LLM Providers ────────────────────────────────────────────
# Groq API key — primary LLM for orchestration + chat (server-side only)
# NEVER prefix with VITE_ — this would expose it in the browser bundle
AI_GROQ_API_KEY=gsk_...

# Optional additional LLM providers (configure in Settings UI)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...

# ── Ollama (Local LLM) ────────────────────────────────────────
# Self-hosted Ollama for privacy-sensitive scraping/extraction.
# Used when VITE_OLLAMA_URL is set and Ollama is reachable.
# These are SAFE to prefix with VITE_ (local machine URL, no secrets)
VITE_OLLAMA_URL=http://localhost:11434
VITE_OLLAMA_MODEL=llama3

# ── Authentication ────────────────────────────────────────────
# JWT secret for session tokens (server-side only)
# JWT_SECRET=your-secret-here

# ── API Security ──────────────────────────────────────────────
# Shared token for internal API calls (scraper, leads-sync, etc.)
XPS_API_TOKEN=xps_...

# ── GitHub Integration ────────────────────────────────────────
# Personal Access Token for cross-repo operations (leads sync, workflow dispatch)
# Requires: repo, workflow scopes
GH_PAT=ghp_...

# Leads repository (where scraped leads are committed as source of truth)
LEADS_REPO_TOKEN=ghp_...
LEADS_REPO_OWNER=InfinityXOneSystems
LEADS_REPO_NAME=XPS-LEADS

# ── Docker Desktop MCP Sync ───────────────────────────────────
# Webhook secret for verifying Docker Desktop sync payloads
DOCKER_WEBHOOK_SECRET=your-webhook-secret

# Docker Desktop webhook URL (set in docker-compose or Desktop settings)
# DOCKER_WEBHOOK_URL=http://host.docker.internal:9000

# ── Vercel CI/CD ──────────────────────────────────────────────
# Set in GitHub repository secrets for CI deployment
# VERCEL_TOKEN=...
# VERCEL_ORG_ID=...
# VERCEL_PROJECT_ID=...
VERCEL_FRONTEND_URL=https://xps-intelligence.vercel.app

