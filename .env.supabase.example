# ═══════════════════════════════════════════════════════════════════════════════
# XPS Intelligence — Supabase Configuration Reference
# ═══════════════════════════════════════════════════════════════════════════════
#
# Supabase manages ALL Postgres for this system.
# It is the single database for BOTH the frontend (Supabase JS SDK) and
# the backend (Railway service connects via DATABASE_URL).
#
# WHERE TO SET THESE:
#   • Frontend browser bundle → Set via Supabase Vercel Integration (auto) OR
#                               manually in Vercel → Settings → Env Vars
#   • Railway backend → Railway → Project → Variables (as DATABASE_URL)
#   • Local dev → .env.local (copy .env.local.example)
#
# ACCOUNT NEEDED:
#   Sign up:   https://supabase.com  (free tier: 2 projects, 500 MB)
#   Organization: InfinityXOneSystems (or your personal account)
#   Project:   nxfbfbipjsfzoefpgrof
#   Plan:      Free (dev) → Pro $25/month (production recommended)
#
# SOFTWARE NEEDED (local CLI):
#   npm install -g supabase
#   supabase login
#   supabase link --project-ref nxfbfbipjsfzoefpgrof
#
# IMPORTANT NOTES:
#   • Supabase is VERCEL-NATIVE — install the Supabase Vercel Integration to
#     auto-sync NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY.
#   • The ANON KEY is NOT a secret — Supabase Row Level Security (RLS) controls
#     data access. Protect your data with RLS policies, not the anon key.
#   • The SERVICE ROLE KEY bypasses RLS — treat it as a secret and ONLY use it
#     server-side (Railway backend). NEVER expose it in browser code.
# ═══════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
# SECTION A — Client/Browser Variables (public — safe to bundle)
#
# How to get these:
#   Supabase Dashboard → https://supabase.com/dashboard
#   → Project "nxfbfbipjsfzoefpgrof"
#   → Settings → API
#   → Copy "Project URL" and "anon public" key
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL
# Used by: supabase-js in the browser, AND by pages/api/ serverless functions
NEXT_PUBLIC_SUPABASE_URL=https://nxfbfbipjsfzoefpgrof.supabase.co

# Supabase anonymous/public key
# Used by: supabase-js in the browser (RLS-protected reads/writes)
# ✅ Safe to include in browser bundle — RLS policies enforce data access
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im54ZmJmYmlwanNmem9lZnBncm9mIiwicm9sZSI6ImFub24iLCJpYXQiOjE3MDAwMDAwMDAsImV4cCI6MjAxNTM2MDAwMH0.YOUR_ACTUAL_KEY_HERE


# ─────────────────────────────────────────────────────────────────────────────
# SECTION B — Server-side Variables (secrets — NEVER in browser code)
#
# How to get these:
#   Supabase Dashboard → Project → Settings → API
#   → "service_role" key (under "Project API keys")
#   ❌ NEVER put this in NEXT_PUBLIC_* or browser-accessible code
# ─────────────────────────────────────────────────────────────────────────────

# Supabase service role key — bypasses Row Level Security (admin operations)
# Used by: Railway backend for admin DB operations (migrations, seeding)
# ❌ Server-side ONLY — set in Railway Variables, NOT in Vercel build vars
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ─────────────────────────────────────────────────────────────────────────────
# SECTION C — Database Connection Strings (for Railway backend)
#
# How to get these:
#   Supabase Dashboard → Project → Settings → Database → Connection String
#   → Select "URI" tab
#   → Copy the connection string
#   → Replace [YOUR-PASSWORD] with your DB password
#
# Password reset: Supabase Dashboard → Settings → Database → Reset database password
# ─────────────────────────────────────────────────────────────────────────────

# Pooled connection (PgBouncer) — for Railway/serverless production use
# Port 6543 | pgbouncer=true for transaction pooling
DATABASE_URL=postgresql://postgres.nxfbfbipjsfzoefpgrof:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection — for schema migrations and Prisma/Drizzle migrate only
# Port 5432 | no pgbouncer
DATABASE_URL_DIRECT=postgresql://postgres.nxfbfbipjsfzoefpgrof:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Supabase project reference (for CLI and Supabase MCP)
SUPABASE_PROJECT_REF=nxfbfbipjsfzoefpgrof


# ─────────────────────────────────────────────────────────────────────────────
# SECTION D — Supabase Auth Configuration
#
# Configure in: Supabase Dashboard → Project → Authentication → Settings
# ─────────────────────────────────────────────────────────────────────────────

# Site URL — the primary URL of your Vercel frontend
# Set in: Supabase → Authentication → URL Configuration → Site URL
SUPABASE_SITE_URL=https://xps-intelligence-frontend.vercel.app

# Redirect URLs — allowed OAuth callback URLs (one per line in the dashboard)
# Add these in: Supabase → Authentication → URL Configuration → Redirect URLs
# https://xps-intelligence-frontend.vercel.app/**
# https://xps-intelligence-frontend-git-main-jays-projects-5febe7fa.vercel.app/**
# http://localhost:5173/**   (local Vite dev server)
# http://localhost:3000/**   (local Docker)


# ─────────────────────────────────────────────────────────────────────────────
# HOW TO INSTALL THE SUPABASE VERCEL INTEGRATION (recommended)
# ─────────────────────────────────────────────────────────────────────────────
#
# This automatically keeps NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY
# in sync in your Vercel project whenever they change in Supabase.
#
# 1. Go to: https://vercel.com/integrations/supabase
# 2. Click "Add Integration"
# 3. Select your Vercel team: jays-projects-5febe7fa
# 4. Click "Continue" → select Vercel project: xps-intelligence-frontend
# 5. Click "Connect to Supabase" → sign in with your Supabase account
# 6. Select Supabase organization and project: nxfbfbipjsfzoefpgrof
# 7. Click "Install" → Done!
#
# The integration will:
#   • Set NEXT_PUBLIC_SUPABASE_URL in all Vercel environments
#   • Set NEXT_PUBLIC_SUPABASE_ANON_KEY in all Vercel environments
#   • Auto-rotate keys if you rotate them in Supabase
#
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE SUPABASE CLI LOCALLY
# ─────────────────────────────────────────────────────────────────────────────
#
# Install: npm install -g supabase
#
# Login:
# supabase login
#
# Link to existing project:
# supabase link --project-ref nxfbfbipjsfzoefpgrof
# (enter database password when prompted)
#
# Pull remote schema to local:
# supabase db pull
#
# Run migrations:
# supabase db push
#
# Start local Supabase stack (Docker required):
# supabase start
# # → gives you local URLs: http://localhost:54321 (API), http://localhost:54323 (Studio)
#
# Stop local Supabase:
# supabase stop
#
# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE TABLE STRUCTURE (reference)
# ─────────────────────────────────────────────────────────────────────────────
#
# Tables managed by this system (see supabase/migrations/ for schemas):
#   leads          — scraped contractor/business leads
#   tasks          — agent task queue and history
#   knowledge      — agent memory + knowledge base
#   outreach_log   — lead outreach tracking
#   sessions       — user auth sessions
#   agent_logs     — AGENT_EXEC_LOGS for all 13 agents
#   scrape_jobs    — scraping job queue and results
#
# Enable Row Level Security on ALL tables:
# ALTER TABLE leads ENABLE ROW LEVEL SECURITY;
# (repeat for each table)
