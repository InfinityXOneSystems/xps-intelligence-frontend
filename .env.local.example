# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must never be committed.

# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:3000/api

# ── Supabase ─────────────────────────────────────────────────
# Your Supabase project URL and anon (public) key.
# The Supabase Vercel integration sets NEXT_PUBLIC_SUPABASE_URL
# automatically; for local Vite dev you must also set VITE_* below.
VITE_SUPABASE_URL=https://nxfbfbipjsfzoefpgrof.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
