# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must never be committed.

# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:3000/api

# ── Supabase ─────────────────────────────────────────────────
# Standard Supabase variable names — used by the Supabase Vercel
# integration, the Supabase CLI (`supabase start`), and this app.
# vite.config.ts sets envPrefix to include NEXT_PUBLIC_ so these
# are automatically baked into the bundle without any VITE_* alias.
NEXT_PUBLIC_SUPABASE_URL=https://nxfbfbipjsfzoefpgrof.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ── Webhooks ──────────────────────────────────────────────────
# Vercel Deploy Hook — triggers an autonomous redeploy of this app.
# Set in Vercel: Project → Settings → Git → Deploy Hooks.
# This is used by the Railway webhook handler (/api/webhooks/railway)
# to redeploy the frontend when a critical Railway event fires.
# Server-side only — never prefix with VITE_ or NEXT_PUBLIC_.
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/prj_eNK90PC48eWsMW3O6aHHRWsM4wwI/ugf4FE56k4

# ── Railway Webhook Setup ─────────────────────────────────────
# In Railway dashboard: Project → Settings → Webhooks → New Webhook
# Webhook URL: https://<your-vercel-domain>/api/webhooks/railway
# Recommended events: DEPLOY_FAILED, BUILD_FAILED, SERVICE_CRASH,
#                     DEPLOY_SUCCEEDED, VOLUME_FULL

