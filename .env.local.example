# ═══════════════════════════════════════════════════════════════════════════════
# XPS Intelligence — Local Development Environment
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and must NEVER be committed.
#
# For full documentation of all vars across all repos/accounts, see .env.example
# and .github/ENV_VARS.md (the GitHub-hosted single source of truth).
#
# ─────────────────────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────────────────────
# 1. FRONTEND RUNTIME (baked into browser bundle by Vite)
# ─────────────────────────────────────────────────────────────────────────────

# Point to local backend, or the Railway staging URL
VITE_API_URL=http://localhost:3000/api

# WebSocket (leave empty if not running backend locally)
# VITE_WS_URL=ws://localhost:3000


# ─────────────────────────────────────────────────────────────────────────────
# 2. SUPABASE (standard names — also accepted by Supabase CLI)
#    Get from: Supabase dashboard → Project → Settings → API
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://nxfbfbipjsfzoefpgrof.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here


# ─────────────────────────────────────────────────────────────────────────────
# 3. VERCEL SERVERLESS FUNCTIONS (server-side — never use VITE_ prefix)
#    In production these are set in Vercel → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# Railway backend base URL
BACKEND_URL=http://localhost:3000

# Groq API key — get from https://console.groq.com/keys
AI_GROQ_API_KEY=gsk_...

# Vercel deploy hook (only needed if testing autonomous redeployment locally)
# VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/prj_.../...


# ─────────────────────────────────────────────────────────────────────────────
# 4. OPTIONAL LLM PROVIDERS
# ─────────────────────────────────────────────────────────────────────────────

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AI...


# ─────────────────────────────────────────────────────────────────────────────
# RAILWAY WEBHOOK SETUP (reference)
# ─────────────────────────────────────────────────────────────────────────────
# In Railway dashboard: Project → Settings → Webhooks → New Webhook
# Webhook URL: https://<your-vercel-domain>/api/webhooks/railway
# Events: DEPLOY_FAILED, BUILD_FAILED, SERVICE_CRASH, DEPLOY_SUCCEEDED, VOLUME_FULL

