# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and must never be committed.
#
# Usage:
#   cp .env.local.example .env.local
#   # Edit .env.local with your actual values
#   npm run dev

# ── Backend (Railway / local) ──────────────────────────────────────────────
# Backend API base URL (no trailing slash)
# Local backend:  http://localhost:3000/api
# Production:     https://xpsintelligencesystem-production.up.railway.app/api
VITE_API_URL=http://localhost:3000/api

# WebSocket URL for real-time agent/scraper updates
# Local:       ws://localhost:3000
# Production:  wss://xpsintelligencesystem-production.up.railway.app
VITE_WS_URL=ws://localhost:3000

# ── Vercel Serverless Functions (pages/api/) ───────────────────────────────
# Used server-side only — never prefix with VITE_
BACKEND_URL=http://localhost:3000

# ── LLM Providers (server-side only — never prefix with VITE_) ────────────
# AI_GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
