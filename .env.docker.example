# ═══════════════════════════════════════════════════════════════════════════════
# XPS Intelligence — Docker Local Development Environment
# ═══════════════════════════════════════════════════════════════════════════════
#
# Docker manages LOCAL development ONLY.
# Production runs on Vercel (frontend) + Railway (backend).
# Never use this file for production deployment.
#
# WHAT RUNS IN DOCKER (local):
#   - xps-frontend        → React app served on :3000 (production build)
#   - webhook-receiver    → GitHub webhook listener on :3001
#   - (optional) Supabase → Local Supabase stack via `supabase start`
#
# HOW TO START:
#   1. cp .env.docker.example .env.local
#   2. Fill in the values below
#   3. docker compose up --build
#
# ACCOUNT NEEDED: None (local only)
#
# SOFTWARE NEEDED:
#   Docker Desktop: https://www.docker.com/products/docker-desktop
#   - macOS:  brew install --cask docker
#   - Linux:  https://docs.docker.com/engine/install
#   - Windows: Docker Desktop for Windows (WSL2 backend recommended)
#   Minimum Docker version: 24.x
#   Minimum Docker Compose: v2.x (included in Docker Desktop)
#
# VERIFY INSTALLATION:
#   docker --version          # Docker version 24.x or higher
#   docker compose version    # Docker Compose version v2.x or higher
# ═══════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
# SECTION A — Frontend Service (xps-frontend container)
#
# These are passed to the Docker container and baked into the Vite build.
# For local dev, point to your locally running backend (or Railway staging).
# ─────────────────────────────────────────────────────────────────────────────

# Backend API URL
# If running XPS_INTELLIGENCE_SYSTEM locally on port 3000:
API_URL=http://localhost:3000/api
# If testing against Railway staging backend:
# API_URL=https://xpsintelligencesystem-staging.up.railway.app/api

# WebSocket URL (leave commented if not running backend locally)
WS_URL=ws://localhost:3000
# WS_URL=wss://xpsintelligencesystem-staging.up.railway.app


# ─────────────────────────────────────────────────────────────────────────────
# SECTION B — Supabase (local or remote)
#
# Option 1: Use the remote Supabase project (recommended for dev)
#   Get these from: Supabase Dashboard → Project → Settings → API
#
# Option 2: Use local Supabase stack
#   Run: supabase start
#   Local API URL: http://localhost:54321
#   Local anon key: shown in `supabase start` output
# ─────────────────────────────────────────────────────────────────────────────

# Remote Supabase (default — always works)
NEXT_PUBLIC_SUPABASE_URL=https://nxfbfbipjsfzoefpgrof.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Local Supabase (comment out remote above and uncomment these)
# NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7W9oQ972PkofJlZHmW8wswyRyAHiUw8RqYg


# ─────────────────────────────────────────────────────────────────────────────
# SECTION C — Vercel Proxy Functions (server-side, for local pages/api/ testing)
#
# When testing Vercel serverless functions locally with `vercel dev`,
# these are read from .env.local by the Vercel CLI.
# ─────────────────────────────────────────────────────────────────────────────

# Railway backend proxy URL (used by pages/api/ proxy functions)
BACKEND_URL=http://localhost:3000

# Groq API key — needed for pages/api/chat.js to work locally
# Get from: https://console.groq.com/keys
AI_GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────────────────────
# SECTION D — Webhook Receiver Service (xps-webhook-receiver container)
#
# The webhook-receiver listens for GitHub push events on port 3001.
# Required if you want the local Docker stack to auto-sync on git push.
# ─────────────────────────────────────────────────────────────────────────────

# Must match the Secret set in GitHub → Repo → Settings → Webhooks
# Generate: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your-local-webhook-secret-here

# GitHub App credentials (for the webhook receiver to comment on PRs etc.)
# Optional — only needed if using GitHub App auth (vs PAT)
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n..."

# Repo the webhook receiver syncs
GITHUB_REPO_OWNER=InfinityXOneSystems
GITHUB_REPO_NAME=XPS-INTELLIGENCE-FRONTEND

# Branches to sync (comma-separated)
SYNC_BRANCHES=main,develop


# ─────────────────────────────────────────────────────────────────────────────
# SECTION E — Optional Local LLM (Ollama)
#
# Run local models with Ollama instead of cloud APIs (no API key needed).
# Useful when offline or to avoid API costs during development.
#
# Install: https://ollama.com/download
# Pull a model: ollama pull llama3.2
# Start: ollama serve  (runs on http://localhost:11434)
# ─────────────────────────────────────────────────────────────────────────────

# OLLAMA_ENDPOINT=http://localhost:11434
# OLLAMA_MODEL=llama3.2


# ─────────────────────────────────────────────────────────────────────────────
# DOCKER COMMANDS REFERENCE
# ─────────────────────────────────────────────────────────────────────────────
#
# Start all services (builds images on first run):
#   docker compose up --build
#
# Start in background (detached):
#   docker compose up -d --build
#
# Stop all services:
#   docker compose down
#
# Stop and remove volumes:
#   docker compose down -v
#
# View logs (all services):
#   docker compose logs -f
#
# View logs (frontend only):
#   docker compose logs -f frontend
#
# Rebuild a single service:
#   docker compose up --build frontend
#
# Open shell in running container:
#   docker compose exec frontend sh
#
# Check container health:
#   docker compose ps
#
# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT WORKFLOW
# ─────────────────────────────────────────────────────────────────────────────
#
# Option A: Docker (production build preview)
#   docker compose up --build
#   → Frontend: http://localhost:3000
#   → Webhook:  http://localhost:3001
#
# Option B: Vite dev server (recommended for active development)
#   cp .env.local.example .env.local   # edit values
#   npm install
#   npm run dev
#   → Frontend: http://localhost:5173  (with HMR)
#
# Option C: Vercel CLI (test serverless functions locally)
#   npm install -g vercel
#   vercel dev
#   → Frontend + API: http://localhost:3000
#
# Option D: Full local stack (Vite + local Supabase + local backend)
#   Terminal 1: supabase start          # local Supabase on :54321
#   Terminal 2: cd XPS_INTELLIGENCE_SYSTEM && railway run npm start  # backend on :3000
#   Terminal 3: npm run dev             # frontend on :5173
