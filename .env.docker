# ─────────────────────────────────────────────────────────────────────────────
# XPS Intelligence Frontend — Docker build & runtime variables
#
# Usage:
#   cp .env.docker .env
#   # Fill in your real values, then:
#   docker compose up --build
#
# DO NOT commit .env — it is git-ignored.
# This file (.env.docker) is the committed template; it contains no secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Vite build-time variables (baked into the JS bundle) ─────────────────────
# These are passed as Docker build ARGs and injected by Vite at build time.
# Change these to point at your Railway backend before building the image.
VITE_API_URL=https://xpsintelligencesystem-production.up.railway.app/api
VITE_WS_URL=wss://xpsintelligencesystem-production.up.railway.app

# ── Runtime / serverless-function variables ───────────────────────────────────
# Used by pages/api/* handlers when running locally with `vercel dev`.
# In production these live in the Vercel dashboard (never in the Docker image).

# Groq API key — server-side only, never prefix with VITE_
AI_GROQ_API_KEY=your_groq_api_key_here

# Railway backend base URL (no trailing slash, no /api suffix)
BACKEND_URL=https://xpsintelligencesystem-production.up.railway.app

# ── GitHub ↔ Docker webhook receiver (optional) ───────────────────────────────
# Only needed if you run the webhook-receiver service from docker-compose.yml.
# GITHUB_WEBHOOK_SECRET=your_32_char_random_secret
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_REPO_OWNER=InfinityXOneSystems
# GITHUB_REPO_NAME=XPS-INTELLIGENCE-FRONTEND
