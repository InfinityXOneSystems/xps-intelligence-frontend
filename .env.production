# ─────────────────────────────────────────────────────────────────────────────
# XPS Intelligence — Production Build-time Variables
# ─────────────────────────────────────────────────────────────────────────────
#
# These VITE_* and NEXT_PUBLIC_* values are baked into the Vite production
# bundle at build time. They are NOT secrets — they are public URLs.
#
# Full source of truth (including server-side secrets): .github/ENV_VARS.md
# and .env.example
# ─────────────────────────────────────────────────────────────────────────────

# Railway backend — must end in /api
VITE_API_URL=https://xpsintelligencesystem-production.up.railway.app/api

# WebSocket for real-time updates
VITE_WS_URL=wss://xpsintelligencesystem-production.up.railway.app

# Supabase — set automatically by the Supabase Vercel integration.
# Do NOT set a hard-coded ANON_KEY here; the integration manages it.
NEXT_PUBLIC_SUPABASE_URL=https://nxfbfbipjsfzoefpgrof.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY → set via Supabase Vercel integration, not here
# VERCEL_DEPLOY_HOOK             → set in Vercel project → Settings → Environment Variables
# BACKEND_URL                    → set in Vercel project → Settings → Environment Variables
# AI_GROQ_API_KEY                → set in Vercel project → Settings → Environment Variables

