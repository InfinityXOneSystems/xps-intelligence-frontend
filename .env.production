# ─────────────────────────────────────────────────────────────────────────────
# XPS Intelligence — Production Build-time Variables
# ─────────────────────────────────────────────────────────────────────────────
#
# These values are injected into the Vite production bundle at build time.
# They are NOT secrets — they are public Railway service URLs.
#
# Full source of truth (including server-side secrets): .github/ENV_VARS.md
# and .env.example
# ─────────────────────────────────────────────────────────────────────────────

# Railway backend — must end in /api
API_URL=https://xpsintelligencesystem-production.up.railway.app/api

# WebSocket for real-time updates
WS_URL=wss://xpsintelligencesystem-production.up.railway.app

# Supabase — set automatically by the Supabase Vercel integration.
# Do NOT set NEXT_PUBLIC_SUPABASE_ANON_KEY here; the integration manages it.
NEXT_PUBLIC_SUPABASE_URL=https://nxfbfbipjsfzoefpgrof.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY → set via Supabase Vercel integration
# VERCEL_DEPLOY_HOOK             → set in Vercel → Settings → Environment Variables
# BACKEND_URL                    → set in Vercel → Settings → Environment Variables
# AI_GROQ_API_KEY                → set in Vercel → Settings → Environment Variables (Vercel-native)

